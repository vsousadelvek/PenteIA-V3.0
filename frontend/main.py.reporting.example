"""
Example integration in main.py to include reporting routes.

Add this to your main FastAPI application file:
"""

# In your main.py or app initialization file:

from fastapi import FastAPI
from routes.reporting import router as reporting_router

app = FastAPI(
    title="PenteIA API",
    description="Penetration Testing Intelligence API",
    version="3.0.0"
)

# Include reporting routes
app.include_router(reporting_router)

# Other routes...
# app.include_router(other_router)

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
